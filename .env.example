# ══════════════════════════════════════════════════════════════════
# DeepFake Worker – Ortam Değişkenleri Örneği
# Kullanım: cp .env.example .env
# ══════════════════════════════════════════════════════════════════

# ── RabbitMQ ──────────────────────────────────────────────────────
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=admin
RABBITMQ_PASS=admin123

# ── Kuyruk İsimleri ───────────────────────────────────────────────
ANALYSIS_QUEUE=analysis_queue
RESULT_QUEUE=result_queue

# ── Worker ────────────────────────────────────────────────────────
WORKER_THREADS=4

# ── Bulut RabbitMQ (Railway / CloudAMQP) ─────────────────────────
# Ayarlandığında RABBITMQ_HOST/PORT/USER/PASS'ı ezer
# RABBITMQ_URL=amqps://user:pass@hostname/vhost

# ── .NET Veritabanı ───────────────────────────────────────────────
# DB_CONNECTION=Server=localhost;Database=DeepFakeDb;User Id=sa;Password=...
